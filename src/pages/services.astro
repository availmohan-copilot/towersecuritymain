---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import QuickContact from '../components/QuickContact.astro';
---

<Layout title="Our Services - The Tower Security Agency">
	<Navigation />

	<section class="page-hero">
		<div class="container">
			<h1>Our Services</h1>
			<p>Comprehensive Security Solutions for Every Need</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Security Services</h2>
				<p>Professional protection with military precision</p>
			</div>
			<div class="services-grid">
				<div class="service-card card">
					<div class="service-icon">🛡️</div>
					<h3>Security Guards</h3>
					<p>Professionally trained security personnel for comprehensive protection of your premises. Our guards are ex-servicemen with extensive experience in maintaining security and order.</p>
					<ul class="service-features">
						<li>24/7 Security Coverage</li>
						<li>Access Control Management</li>
						<li>Patrol Services</li>
						<li>Incident Reporting</li>
					</ul>
				</div>

				<div class="service-card card">
					<div class="service-icon">👮</div>
					<h3>Security Officers</h3>
					<p>Senior security professionals with advanced training to supervise and manage security operations at your facility with strategic oversight.</p>
					<ul class="service-features">
						<li>Security Operations Management</li>
						<li>Team Supervision</li>
						<li>Risk Assessment</li>
						<li>Emergency Response Coordination</li>
					</ul>
				</div>

				<div class="service-card card">
					<div class="service-icon">🔫</div>
					<h3>Armed Guards</h3>
					<p>Guards with weapons provide safety for your assets from a variety of hazards. Trained in firearms and tactical response for high-security environments.</p>
					<ul class="service-features">
						<li>Licensed Armed Personnel</li>
						<li>High-Value Asset Protection</li>
						<li>Tactical Response Training</li>
						<li>Threat Deterrence</li>
					</ul>
				</div>

				<div class="service-card card">
					<div class="service-icon">👁️</div>
					<h3>Surveillance Cameras</h3>
					<p>We ensure 100% Safety of your Premises by Installing Advanced technology and watching them 24/7, which is also cost effective.</p>
					<ul class="service-features">
						<li>CCTV Installation & Monitoring</li>
						<li>24/7 Live Monitoring</li>
						<li>Recording & Playback</li>
						<li>Remote Access Capability</li>
					</ul>
				</div>

				<div class="service-card card">
					<div class="service-icon">🚗</div>
					<h3>VIP & Software Company Escorts</h3>
					<p>Personal Safety for VIP, VVIPs and Software professionals. Discreet and professional protection services for high-profile individuals.</p>
					<ul class="service-features">
						<li>Executive Protection</li>
						<li>Safe Transportation</li>
						<li>Event Security</li>
						<li>Threat Assessment</li>
					</ul>
				</div>

				<div class="service-card card">
					<div class="service-icon">💪</div>
					<h3>Bouncers</h3>
					<p>To prevent from troublemakers and unwanted people. Professional crowd management and access control for events, clubs, and establishments.</p>
					<ul class="service-features">
						<li>Crowd Control</li>
						<li>Access Management</li>
						<li>Conflict Resolution</li>
						<li>Event Security</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="section" style="background: var(--light);">
		<div class="container">
			<div class="section-title">
				<h2>Manpower Services</h2>
				<p>Skilled and reliable workforce solutions</p>
			</div>
			<div class="manpower-content">
				<div class="manpower-text">
					<h3>Skilled and Unskilled Labour</h3>
					<p>We provide comprehensive manpower services to meet your operational requirements. Our workforce includes both skilled professionals and unskilled labor, carefully selected and trained for various industrial and commercial needs.</p>
					<div class="manpower-features">
						<div class="feature-item">
							<h4>Computer Literate Personnel</h4>
							<p>Organizations requiring security staff with computer knowledge to handle daily documentation and records work can benefit from our specially trained personnel.</p>
						</div>
						<div class="feature-item">
							<h4>Flexible Deployment</h4>
							<p>We deploy personnel suited to your specific needs, whether temporary or permanent positions.</p>
						</div>
						<div class="feature-item">
							<h4>Quality Assurance</h4>
							<p>All personnel undergo thorough background verification and screening before deployment.</p>
						</div>
					</div>
				</div>
				<div class="manpower-image">
					<img src="https://images.pexels.com/photos/5668858/pexels-photo-5668858.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Professional Team">
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Training & Development</h2>
				<p>Building excellence through comprehensive training</p>
			</div>
			<div class="training-content">
				<p class="training-intro">It is mandatory for all security personnel to undergo a basic training course which imparts the necessary skill to perform duties in addition to the lesson on basic guarding skills.</p>

				<div class="training-grid">
					<div class="training-card">
						<h4>Basic Security Training</h4>
						<p>Comprehensive training in security protocols, access control, patrol techniques, and incident response.</p>
					</div>
					<div class="training-card">
						<h4>Industrial Security</h4>
						<p>Specialized training in industrial security requirements, documentation, and compliance procedures.</p>
					</div>
					<div class="training-card">
						<h4>Public Relations</h4>
						<p>Communication skills and professional conduct training for effective interaction with clients and visitors.</p>
					</div>
					<div class="training-card">
						<h4>Firefighting</h4>
						<p>Fire safety procedures, equipment handling, and emergency evacuation protocols.</p>
					</div>
					<div class="training-card">
						<h4>First Aid</h4>
						<p>Basic medical emergency response and first aid procedures for immediate assistance.</p>
					</div>
					<div class="training-card">
						<h4>Self Defense</h4>
						<p>Physical training in self-defense techniques and conflict management.</p>
					</div>
					<div class="training-card">
						<h4>Crisis Management</h4>
						<p>Training in handling emergency situations, threat assessment, and crisis response.</p>
					</div>
					<div class="training-card">
						<h4>On-the-Job Training</h4>
						<p>Personnel are put on practical training in selected establishments before final deployment.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section" style="background: var(--primary); color: var(--white);">
		<div class="container">
			<div class="cta-service">
				<h2>Need a Custom Security Solution?</h2>
				<p>We tailor our services to meet your specific security requirements and budget. Contact us for a free consultation.</p>
				<a href="#contact" class="btn btn-primary">Get Free Consultation</a>
			</div>
		</div>
	</section>

	<div id="contact">
		<QuickContact />
	</div>

	<Footer />
</Layout>

<style>
	.page-hero {
		background: linear-gradient(135deg, var(--primary), var(--accent));
		color: var(--white);
		padding: 120px 0 80px;
		text-align: center;
	}

	.page-hero h1 {
		font-size: 3.5rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.3rem;
		opacity: 0.9;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 30px;
	}

	.service-card {
		padding: 40px 30px;
	}

	.service-icon {
		font-size: 4rem;
		margin-bottom: 25px;
	}

	.service-card h3 {
		color: var(--primary);
		font-size: 1.5rem;
		margin-bottom: 20px;
	}

	.service-card p {
		color: var(--text-light);
		line-height: 1.8;
		margin-bottom: 25px;
	}

	.service-features {
		list-style: none;
		padding: 0;
	}

	.service-features li {
		padding: 10px 0;
		color: var(--text-light);
		border-bottom: 1px solid #e0e0e0;
		position: relative;
		padding-left: 25px;
	}

	.service-features li:last-child {
		border-bottom: none;
	}

	.service-features li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--gold);
		font-weight: bold;
	}

	.manpower-content {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.manpower-text h3 {
		color: var(--primary);
		font-size: 2rem;
		margin-bottom: 20px;
	}

	.manpower-text > p {
		color: var(--text-light);
		font-size: 1.1rem;
		line-height: 1.8;
		margin-bottom: 30px;
	}

	.manpower-features {
		display: flex;
		flex-direction: column;
		gap: 25px;
	}

	.feature-item {
		padding: 20px;
		background: var(--white);
		border-radius: 8px;
		border-left: 4px solid var(--gold);
	}

	.feature-item h4 {
		color: var(--primary);
		font-size: 1.2rem;
		margin-bottom: 10px;
	}

	.feature-item p {
		color: var(--text-light);
		line-height: 1.7;
	}

	.manpower-image img {
		width: 100%;
		border-radius: 10px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.2);
	}

	.training-intro {
		text-align: center;
		font-size: 1.15rem;
		color: var(--text-light);
		max-width: 800px;
		margin: 0 auto 50px;
		line-height: 1.8;
	}

	.training-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 25px;
	}

	.training-card {
		padding: 30px;
		background: var(--white);
		border-radius: 10px;
		box-shadow: 0 5px 15px rgba(0,0,0,0.1);
		transition: all 0.3s ease;
		border-top: 3px solid var(--gold);
	}

	.training-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.15);
	}

	.training-card h4 {
		color: var(--primary);
		font-size: 1.2rem;
		margin-bottom: 12px;
	}

	.training-card p {
		color: var(--text-light);
		line-height: 1.7;
		margin: 0;
	}

	.cta-service {
		text-align: center;
		max-width: 700px;
		margin: 0 auto;
	}

	.cta-service h2 {
		font-size: 2.5rem;
		margin-bottom: 20px;
	}

	.cta-service p {
		font-size: 1.2rem;
		margin-bottom: 35px;
		opacity: 0.9;
	}

	@media (max-width: 768px) {
		.page-hero {
			padding: 100px 0 60px;
		}

		.page-hero h1 {
			font-size: 2.2rem;
		}

		.page-hero p {
			font-size: 1.1rem;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}

		.manpower-content {
			grid-template-columns: 1fr;
		}

		.manpower-image {
			order: -1;
		}

		.training-grid {
			grid-template-columns: 1fr;
		}

		.cta-service h2 {
			font-size: 1.8rem;
		}
	}
</style>
