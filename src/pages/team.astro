---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import QuickContact from '../components/QuickContact.astro';
---

<Layout title="Our Team - The Tower Security Agency">
	<Navigation />

	<section class="page-hero">
		<div class="container">
			<h1>Our Team</h1>
			<p>Led by Veterans, Powered by Excellence</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Leadership</h2>
				<p>Experienced professionals guiding our mission</p>
			</div>
			<div class="leadership-content">
				<div class="leader-card">
					<div class="leader-image">
						<img src="/md.png" alt="Managing Director">
					</div>
					<div class="leader-info">
						<h3>Mr. R.D. Moorthy</h3>
						<p class="leader-title">Managing Director</p>
						<p class="leader-desc">Ex-Service Gentleman with extensive experience in security operations and management. Leading The Tower Security Agency with military precision and dedication to client safety.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section" style="background: var(--light);">
		<div class="container">
			<div class="section-title">
				<h2>Our Team Structure</h2>
				<p>Organized for excellence and efficiency</p>
			</div>
			<div class="team-structure">
				<p class="structure-intro">Our team works on the principles of decentralization and direct control thereby everyone who plays their role ensures that our clients do not have any difficulty in accessing the agency.</p>

				<div class="structure-tiers">
					<div class="tier-card card">
						<div class="tier-icon">👔</div>
						<h3>Directors</h3>
						<p>Strategic leadership and policy formulation. Veterans of Defence forces, Police and Human Resources, each bringing specialized skills in different areas.</p>
					</div>
					<div class="tier-card card">
						<div class="tier-icon">👨‍💼</div>
						<h3>Managers</h3>
						<p>Operational management and client coordination. Experienced professionals ensuring seamless service delivery and quality control.</p>
					</div>
					<div class="tier-card card">
						<div class="tier-icon">🛡️</div>
						<h3>Security Staff</h3>
						<p>Front-line security personnel. Ex-servicemen or trained civilians providing on-ground security services with discipline and dedication.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Controllers & Guiding Experts</h2>
				<p>Expertise from diverse fields strengthening our organization</p>
			</div>
			<div class="experts-content">
				<div class="experts-text">
					<p>The promoters of the company consist of veterans of Defence forces, Police and Human Resources, with each one of them claiming their specialized skills in different areas thereby contributing to the strength of the organization.</p>
					<p>Besides expertise from different fields have been drawn with sufficient seniority and prolonged experience who assist the company in formulation of policies and principles.</p>
				</div>
				<div class="expertise-grid">
					<div class="expertise-card">
						<div class="expertise-icon">🎖️</div>
						<h4>Defence Forces Veterans</h4>
						<p>Tactical operations, discipline, and strategic security planning</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">🚓</div>
						<h4>Police Background</h4>
						<p>Law enforcement, investigation, and security protocols</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">👥</div>
						<h4>Human Resources</h4>
						<p>Personnel management, training, and development</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">🔥</div>
						<h4>Fire & Safety</h4>
						<p>Emergency response, firefighting, and safety protocols</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">📹</div>
						<h4>Surveillance</h4>
						<p>Advanced monitoring systems and technology integration</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">🤝</div>
						<h4>Public Relations</h4>
						<p>Client communication and stakeholder management</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">🏥</div>
						<h4>First Aid</h4>
						<p>Medical emergency response and health safety</p>
					</div>
					<div class="expertise-card">
						<div class="expertise-icon">⚡</div>
						<h4>Technical Background</h4>
						<p>Technology systems, documentation, and allied services</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section" style="background: var(--primary); color: var(--white);">
		<div class="container">
			<div class="section-title">
				<h2 style="color: var(--white);">Supervision & Quality Control</h2>
				<p style="color: rgba(255,255,255,0.8);">Constant monitoring for excellent service delivery</p>
			</div>
			<div class="supervision-content">
				<div class="supervision-card">
					<h3>Patrolling Supervisors</h3>
					<p>Our patrolling supervisors who are equipped with communication tools, acting as an interface with all concerned are constantly checking on our personnel to upkeep our commitment.</p>
				</div>
				<div class="supervision-features">
					<div class="feature">
						<h4>Communication Tools</h4>
						<p>Modern communication equipment for instant coordination</p>
					</div>
					<div class="feature">
						<h4>Regular Inspections</h4>
						<p>Frequent checks to ensure quality and discipline</p>
					</div>
					<div class="feature">
						<h4>Direct Interface</h4>
						<p>Easy accessibility for clients and immediate response</p>
					</div>
					<div class="feature">
						<h4>Performance Monitoring</h4>
						<p>Continuous evaluation and improvement initiatives</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Why Our Team Stands Out</h2>
				<p>Excellence through experience and commitment</p>
			</div>
			<div class="standout-grid">
				<div class="standout-card">
					<h4>Military Discipline</h4>
					<p>Ex-servicemen bring unmatched discipline, training, and commitment to duty</p>
				</div>
				<div class="standout-card">
					<h4>Diverse Expertise</h4>
					<p>Team members with specialized skills from various professional backgrounds</p>
				</div>
				<div class="standout-card">
					<h4>Professional Training</h4>
					<p>Mandatory comprehensive training programs for all security personnel</p>
				</div>
				<div class="standout-card">
					<h4>Direct Access</h4>
					<p>Decentralized structure ensuring easy client access and communication</p>
				</div>
				<div class="standout-card">
					<h4>Quality Focus</h4>
					<p>Constant supervision and quality control measures for service excellence</p>
				</div>
				<div class="standout-card">
					<h4>Client-Centric</h4>
					<p>Every team member dedicated to meeting and exceeding client expectations</p>
				</div>
			</div>
		</div>
	</section>

	<QuickContact />
	<Footer />
</Layout>

<style>
	.page-hero {
		background: linear-gradient(135deg, var(--primary), var(--accent));
		color: var(--white);
		padding: 120px 0 80px;
		text-align: center;
	}

	.page-hero h1 {
		font-size: 3.5rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.3rem;
		opacity: 0.9;
	}

	.leader-card {
		display: grid;
		grid-template-columns: 300px 1fr;
		gap: 50px;
		align-items: center;
		max-width: 900px;
		margin: 0 auto;
		background: var(--white);
		padding: 40px;
		border-radius: 10px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
	}

	.leader-image img {
		width: 100%;
		border-radius: 10px;
		box-shadow: 0 5px 15px rgba(0,0,0,0.2);
	}

	.leader-info h3 {
		color: var(--primary);
		font-size: 2rem;
		margin-bottom: 10px;
	}

	.leader-title {
		color: var(--gold);
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 20px;
	}

	.leader-desc {
		color: var(--text-light);
		font-size: 1.1rem;
		line-height: 1.8;
	}

	.structure-intro {
		text-align: center;
		font-size: 1.15rem;
		color: var(--text-light);
		max-width: 800px;
		margin: 0 auto 50px;
		line-height: 1.8;
	}

	.structure-tiers {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 30px;
	}

	.tier-card {
		text-align: center;
		padding: 40px 30px;
	}

	.tier-icon {
		font-size: 4rem;
		margin-bottom: 25px;
	}

	.tier-card h3 {
		color: var(--primary);
		font-size: 1.5rem;
		margin-bottom: 20px;
	}

	.tier-card p {
		color: var(--text-light);
		line-height: 1.8;
	}

	.experts-text {
		margin-bottom: 40px;
	}

	.experts-text p {
		color: var(--text-light);
		font-size: 1.1rem;
		line-height: 1.8;
		margin-bottom: 20px;
	}

	.expertise-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 25px;
	}

	.expertise-card {
		background: var(--white);
		padding: 30px 25px;
		border-radius: 10px;
		box-shadow: 0 5px 15px rgba(0,0,0,0.1);
		transition: all 0.3s ease;
		border-left: 4px solid var(--gold);
	}

	.expertise-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.15);
	}

	.expertise-icon {
		font-size: 2.5rem;
		margin-bottom: 15px;
	}

	.expertise-card h4 {
		color: var(--primary);
		font-size: 1.2rem;
		margin-bottom: 10px;
	}

	.expertise-card p {
		color: var(--text-light);
		line-height: 1.6;
		font-size: 0.95rem;
	}

	.supervision-content {
		max-width: 1000px;
		margin: 0 auto;
	}

	.supervision-card {
		background: rgba(255,255,255,0.1);
		padding: 40px;
		border-radius: 10px;
		margin-bottom: 40px;
		text-align: center;
	}

	.supervision-card h3 {
		color: var(--gold);
		font-size: 2rem;
		margin-bottom: 20px;
	}

	.supervision-card p {
		font-size: 1.15rem;
		line-height: 1.8;
		opacity: 0.9;
	}

	.supervision-features {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 25px;
	}

	.feature {
		background: rgba(255,255,255,0.1);
		padding: 25px;
		border-radius: 8px;
		border-top: 3px solid var(--gold);
	}

	.feature h4 {
		color: var(--gold);
		font-size: 1.2rem;
		margin-bottom: 12px;
	}

	.feature p {
		opacity: 0.85;
		line-height: 1.6;
	}

	.standout-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 30px;
	}

	.standout-card {
		background: var(--white);
		padding: 35px 30px;
		border-radius: 10px;
		box-shadow: 0 5px 15px rgba(0,0,0,0.1);
		transition: all 0.3s ease;
		border-top: 4px solid var(--gold);
	}

	.standout-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.15);
	}

	.standout-card h4 {
		color: var(--primary);
		font-size: 1.3rem;
		margin-bottom: 15px;
	}

	.standout-card p {
		color: var(--text-light);
		line-height: 1.7;
	}

	@media (max-width: 768px) {
		.page-hero {
			padding: 100px 0 60px;
		}

		.page-hero h1 {
			font-size: 2.2rem;
		}

		.page-hero p {
			font-size: 1.1rem;
		}

		.leader-card {
			grid-template-columns: 1fr;
			padding: 30px 20px;
		}

		.leader-image {
			max-width: 250px;
			margin: 0 auto;
		}

		.structure-tiers,
		.expertise-grid,
		.supervision-features,
		.standout-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
