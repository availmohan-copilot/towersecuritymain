---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import QuickContact from '../components/QuickContact.astro';
---

<Layout title="Licenses & Registrations - The Tower Security Agency">
	<Navigation />

	<section class="page-hero">
		<div class="container">
			<h1>Licenses & Registrations</h1>
			<p>Fully Licensed and Certified Security Agency</p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Our Registrations</h2>
				<p>Authorized and compliant with all regulatory requirements</p>
			</div>
			<div class="intro-text">
				<p>The Tower Security Agency operates with all necessary licenses and registrations as mandated by the Government of India and State authorities. Our compliance ensures that we provide you with legally authorized and professionally managed security services.</p>
			</div>
		</div>
	</section>

	<section class="section" style="background: var(--light);">
		<div class="container">
			<div class="licenses-grid">
				<div class="license-card card">
					<div class="license-icon">🛡️</div>
					<h3>PSAR Act License</h3>
					<div class="license-details">
						<div class="detail-row">
							<span class="label">License Number:</span>
							<span class="value">223/2010</span>
						</div>
						<div class="detail-row">
							<span class="label">Issued By:</span>
							<span class="value">Inspector General of Police Welfare</span>
						</div>
						<div class="detail-row">
							<span class="label">Authority:</span>
							<span class="value">Controlling Authority</span>
						</div>
						<div class="detail-row">
							<span class="label">Act:</span>
							<span class="value">Private Security Agencies (Regulation) Act, 2005</span>
						</div>
					</div>
					<p class="license-desc">This license authorizes us to provide private security services as per the PSAR Act 2005 regulations.</p>
				</div>

				<div class="license-card card">
					<div class="license-icon">💼</div>
					<h3>EPF Registration</h3>
					<div class="license-details">
						<div class="detail-row">
							<span class="label">EPF Code Number:</span>
							<span class="value">TN/AMB/68197</span>
						</div>
						<div class="detail-row">
							<span class="label">Organization:</span>
							<span class="value">Employees' Provident Fund Organisation</span>
						</div>
						<div class="detail-row">
							<span class="label">Coverage:</span>
							<span class="value">All Eligible Employees</span>
						</div>
					</div>
					<p class="license-desc">Our EPF registration ensures social security benefits for all our employees as per statutory requirements.</p>
				</div>

				<div class="license-card card">
					<div class="license-icon">🏥</div>
					<h3>ESI Registration</h3>
					<div class="license-details">
						<div class="detail-row">
							<span class="label">ESI Code Number:</span>
							<span class="value">51001104640001018</span>
						</div>
						<div class="detail-row">
							<span class="label">Organization:</span>
							<span class="value">Employees' State Insurance Corporation</span>
						</div>
						<div class="detail-row">
							<span class="label">Benefits:</span>
							<span class="value">Medical & Health Insurance</span>
						</div>
					</div>
					<p class="license-desc">ESI coverage provides comprehensive medical and health benefits to all our security personnel.</p>
				</div>

				<div class="license-card card">
					<div class="license-icon">📋</div>
					<h3>GST Registration</h3>
					<div class="license-details">
						<div class="detail-row">
							<span class="label">GSTIN:</span>
							<span class="value">33AAFFT8496C1ZZ</span>
						</div>
						<div class="detail-row">
							<span class="label">State:</span>
							<span class="value">Tamil Nadu</span>
						</div>
						<div class="detail-row">
							<span class="label">Status:</span>
							<span class="value">Active & Compliant</span>
						</div>
					</div>
					<p class="license-desc">GST registered entity ensuring complete tax compliance and transparency in all business transactions.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-title">
				<h2>Why Our Certifications Matter</h2>
				<p>Legal compliance and professional standards</p>
			</div>
			<div class="importance-grid">
				<div class="importance-card">
					<div class="importance-icon">✓</div>
					<h4>Legal Authorization</h4>
					<p>Licensed under PSAR Act 2005, ensuring we operate within the legal framework established by the Government of India.</p>
				</div>
				<div class="importance-card">
					<div class="importance-icon">✓</div>
					<h4>Employee Welfare</h4>
					<p>EPF and ESI registrations guarantee that our personnel receive statutory benefits and social security coverage.</p>
				</div>
				<div class="importance-card">
					<div class="importance-icon">✓</div>
					<h4>Tax Compliance</h4>
					<p>GST registration ensures complete transparency and compliance with tax regulations for all business operations.</p>
				</div>
				<div class="importance-card">
					<div class="importance-icon">✓</div>
					<h4>Quality Assurance</h4>
					<p>Regulatory compliance reflects our commitment to maintaining the highest standards of service quality.</p>
				</div>
				<div class="importance-card">
					<div class="importance-icon">✓</div>
					<h4>Client Trust</h4>
					<p>Proper licensing and registrations provide our clients with confidence in our professional operations.</p>
				</div>
				<div class="importance-card">
					<div class="importance-icon">✓</div>
					<h4>Accountability</h4>
					<p>Being a registered and licensed entity ensures accountability and adherence to industry regulations.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section" style="background: var(--primary); color: var(--white);">
		<div class="container">
			<div class="section-title">
				<h2 style="color: var(--white);">PSAR Act 2005</h2>
				<p style="color: rgba(255,255,255,0.8);">Understanding the regulatory framework</p>
			</div>
			<div class="psar-content">
				<div class="psar-text">
					<h3>Private Security Agencies (Regulation) Act, 2005</h3>
					<p>The PSAR Act 2005 is a comprehensive legislation enacted by the Government of India to regulate private security agencies and ensure professional standards in the security industry.</p>

					<div class="psar-points">
						<div class="psar-point">
							<h4>Regulatory Framework</h4>
							<p>Establishes guidelines for licensing, operation, and management of private security agencies.</p>
						</div>
						<div class="psar-point">
							<h4>Quality Standards</h4>
							<p>Mandates training requirements and operational standards for security personnel.</p>
						</div>
						<div class="psar-point">
							<h4>Client Protection</h4>
							<p>Ensures clients receive services from authorized and professionally managed agencies.</p>
						</div>
						<div class="psar-point">
							<h4>Accountability</h4>
							<p>Creates a framework for monitoring and accountability of private security services.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="verification-section">
				<div class="section-title">
					<h2>Verification & Compliance</h2>
					<p>Committed to transparency and regulatory adherence</p>
				</div>
				<div class="verification-content">
					<div class="verification-card card">
						<h3>Regular Audits</h3>
						<p>Our operations are subject to regular audits by regulatory authorities to ensure continued compliance with all applicable laws and regulations.</p>
					</div>
					<div class="verification-card card">
						<h3>Documentation</h3>
						<p>We maintain comprehensive documentation of all licenses, registrations, and compliance certificates available for client verification.</p>
					</div>
					<div class="verification-card card">
						<h3>Renewal & Updates</h3>
						<p>All licenses and registrations are kept current with timely renewals and updates as per regulatory requirements.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<QuickContact />
	<Footer />
</Layout>

<style>
	.page-hero {
		background: linear-gradient(135deg, var(--primary), var(--accent));
		color: var(--white);
		padding: 120px 0 80px;
		text-align: center;
	}

	.page-hero h1 {
		font-size: 3.5rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.3rem;
		opacity: 0.9;
	}

	.intro-text {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}

	.intro-text p {
		font-size: 1.15rem;
		color: var(--text-light);
		line-height: 1.9;
	}

	.licenses-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 30px;
	}

	.license-card {
		padding: 40px 35px;
	}

	.license-icon {
		font-size: 4rem;
		margin-bottom: 25px;
		text-align: center;
	}

	.license-card h3 {
		color: var(--primary);
		font-size: 1.6rem;
		margin-bottom: 25px;
		text-align: center;
	}

	.license-details {
		background: var(--light);
		padding: 25px;
		border-radius: 8px;
		margin-bottom: 25px;
	}

	.detail-row {
		display: flex;
		justify-content: space-between;
		padding: 12px 0;
		border-bottom: 1px solid #ddd;
	}

	.detail-row:last-child {
		border-bottom: none;
	}

	.detail-row .label {
		color: var(--text-light);
		font-weight: 500;
		font-size: 0.95rem;
	}

	.detail-row .value {
		color: var(--primary);
		font-weight: 600;
		text-align: right;
		font-size: 0.95rem;
	}

	.license-desc {
		color: var(--text-light);
		line-height: 1.7;
		font-size: 1.05rem;
	}

	.importance-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 30px;
	}

	.importance-card {
		background: var(--white);
		padding: 35px 30px;
		border-radius: 10px;
		box-shadow: 0 5px 15px rgba(0,0,0,0.1);
		transition: all 0.3s ease;
		border-left: 4px solid var(--gold);
	}

	.importance-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.15);
	}

	.importance-icon {
		font-size: 3rem;
		color: var(--gold);
		margin-bottom: 20px;
		font-weight: bold;
	}

	.importance-card h4 {
		color: var(--primary);
		font-size: 1.3rem;
		margin-bottom: 15px;
	}

	.importance-card p {
		color: var(--text-light);
		line-height: 1.7;
	}

	.psar-text {
		max-width: 1000px;
		margin: 0 auto;
	}

	.psar-text h3 {
		color: var(--gold);
		font-size: 2rem;
		margin-bottom: 20px;
		text-align: center;
	}

	.psar-text > p {
		font-size: 1.15rem;
		line-height: 1.8;
		opacity: 0.9;
		text-align: center;
		margin-bottom: 40px;
	}

	.psar-points {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 25px;
	}

	.psar-point {
		background: rgba(255,255,255,0.1);
		padding: 30px 25px;
		border-radius: 8px;
	}

	.psar-point h4 {
		color: var(--gold);
		font-size: 1.2rem;
		margin-bottom: 12px;
	}

	.psar-point p {
		opacity: 0.85;
		line-height: 1.7;
	}

	.verification-content {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 30px;
		margin-top: 40px;
	}

	.verification-card {
		padding: 35px 30px;
	}

	.verification-card h3 {
		color: var(--primary);
		font-size: 1.4rem;
		margin-bottom: 20px;
	}

	.verification-card p {
		color: var(--text-light);
		line-height: 1.8;
		font-size: 1.05rem;
	}

	@media (max-width: 768px) {
		.page-hero {
			padding: 100px 0 60px;
		}

		.page-hero h1 {
			font-size: 2.2rem;
		}

		.page-hero p {
			font-size: 1.1rem;
		}

		.licenses-grid,
		.importance-grid,
		.psar-points,
		.verification-content {
			grid-template-columns: 1fr;
		}

		.detail-row {
			flex-direction: column;
			gap: 5px;
		}

		.detail-row .value {
			text-align: left;
		}
	}
</style>
